# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Service role key for external API authentication (bypasses RLS)
# Get this from Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Test user credentials for E2E tests and screenshot scripts
TEST_USER_EMAIL=your-test-email@example.com
TEST_USER_PASSWORD=your-test-password

# Optional: for editor image uploads, create a public Storage bucket named "images" in Supabase.
# If the bucket is missing, images are embedded as Data URLs (no setup needed, but document size grows).
